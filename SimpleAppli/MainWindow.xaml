<Window x:Class="SimpleAppli.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SimpleAppli"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Window.Resources>
        <Style x:Key="MesureStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="50 10 10 10"></Setter>
            <Setter Property="Foreground" Value="Green"></Setter>
            <Style.Triggers>
                <DataTrigger Value="false" Binding="{Binding Conforme}">
                    <Setter Property="Foreground" Value="Red"></Setter>
                </DataTrigger>
            </Style.Triggers>
            
        </Style>
    </Window.Resources>
    <Grid>
        <ItemsControl ItemsSource="{Binding Mesures}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Style="{StaticResource MesureStyle}" Text="{Binding Value}"></TextBlock>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Window>
