<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
                    xmlns:c="clr-namespace:CapteurNS">

    <!-- Style pour l'affichage des mesures -->
    <sys:Double x:Key="fontsize">16</sys:Double>
    <Style x:Key="MesureStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource fontsize}"></Setter>
        <Setter Property="Margin" Value="50 10 10 10" />
        <Setter Property="Foreground" Value="Green" />
        <Style.Triggers>
            <DataTrigger Value="false" Binding="{Binding Conforme}">
                <Setter Property="Foreground" Value="Red" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Template spécifique pour CapteurNewValueEventArgs<int> -->
    <DataTemplate x:Key="IntCapteur">
        <TextBlock Style="{StaticResource MesureStyle}" Text="{Binding Value}" />
    </DataTemplate>

</ResourceDictionary>