<UserControl x:Class="SimpleWPF.Menu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SimpleWPF"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <DataTemplate x:Key="ButtonTemplate">
            <Button Content="{Binding Libelle}" ></Button>
        </DataTemplate>
    </UserControl.Resources>
    <Grid Background="blue">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
        </Grid.RowDefinitions>
        <ItemsControl ItemsSource="{Binding TopButtons}" ItemTemplate="{StaticResource ButtonTemplate}"></ItemsControl>
        <ItemsControl Grid.Row="1"  ItemsSource="{Binding BottomButtons}" ItemTemplate="{StaticResource ButtonTemplate}"></ItemsControl>
    </Grid>
</UserControl>
