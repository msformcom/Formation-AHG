<UserControl x:Class="MonApp.Controls.PointDisplay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MonApp.Controls"
             xmlns:m="clr-namespace:MonApp.Model"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" >


    <StackPanel>
        <TextBox Text="{Binding X, UpdateSourceTrigger=PropertyChanged}"></TextBox>
        <TextBox Text="{Binding Y}"></TextBox>
        <TextBlock Text="{Binding Norme}"></TextBlock>
    </StackPanel>
</UserControl>
