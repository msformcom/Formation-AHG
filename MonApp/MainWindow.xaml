<Window x:Class="MonApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MonApp"
         xmlns:c="clr-namespace:MonApp.Controls"
        xmlns:m="clr-namespace:MonApp.Model"
        xmlns:vm="clr-namespace:MonApp.ViewModels"
        mc:Ignorable="d"
        Background="Wheat"
        Title="MainWindow" Height="450" Width="800">
    <Window.DataContext>
        <vm:IPointVM>
            <vm:IPointVM.Model>
                 <m:PointPlan X="1" Y="2"></m:PointPlan>
            </vm:IPointVM.Model>
        </vm:IPointVM>
       
    </Window.DataContext>
    <StackPanel>
        <c:PointDisplay></c:PointDisplay>
        <c:PointDisplay></c:PointDisplay>
    </StackPanel>
</Window>
